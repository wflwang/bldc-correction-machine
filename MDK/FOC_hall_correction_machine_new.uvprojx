<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="project_projx.xsd">
  <SchemaVersion>2.1</SchemaVersion>
  <Header>### uVision Project, (C) Keil Software</Header>
  <Targets>
    <Target>
      <TargetName>Target 1</TargetName>
      <ToolsetNumber>0x4</ToolsetNumber>
      <ToolsetName>ARM-ADS</ToolsetName>
      <uAC6>1</uAC6>
      <TargetOption>
        <TargetCommonOption>
          <Device>HK32M070K6U7</Device>
          <Vendor>HK_MicroChip</Vendor>
          <PackID>HKMicroChip.HK32M07x_DFP.1.0.3</PackID>
          <PackURL>http://www.hsxp-hk.com/companyfile/2/</PackURL>
          <Cpu>IRAM(0x20000000,0x8000) IROM(0x08000000,0x40000) CPUTYPE("Cortex-M0") CLOCK(64000000) ELITTLE</Cpu>
          <FlashDriverDll>UL2CM3(-S0 -C0 -P0 -FD20000000 -FC1000 -FN1 -FF0HK32M07x_MEM_32K -FS08000000 -FL08000 -FP0($$Device:HK32M070K6U7$Flash\HK32M07x_MEM_32K.FLM))</FlashDriverDll>
          <OutputDirectory>Objects</OutputDirectory>
          <OutputName>FOC_hall_correction_machine</OutputName>
          <CreateExecutable>1</CreateExecutable>
          <CreateLib>0</CreateLib>
          <CreateHexFile>1</CreateHexFile>
          <DebugInformation>1</DebugInformation>
          <BrowseInformation>1</BrowseInformation>
          <ListingPath>Listings</ListingPath>
        </TargetCommonOption>
        <TargetArmAds>
          <Cads>
            <VariousControls>
              <Define>USE_HAL_DRIVER,HK32M07x,SYSTEM_CORE_CLOCK=64000000</Define>
              <IncludePath>../Mcu/HK32M070/Driver/CMSIS/CM0/Core;../Mcu/HK32M070/Driver/CMSIS/HK32M07x/Include;../Mcu/HK32M070/Driver/HK32M07x_StdPeriphDriver/inc;../Mcu/HK32M070/Inc;../User;../hwconf;../motor;../util</IncludePath>
            </VariousControls>
          </Cads>
        </TargetArmAds>
      </TargetOption>
      <Groups>
        <Group>
          <GroupName>CMSIS</GroupName>
          <Files>
            <File>
              <FileName>../Mcu/HK32M070/Driver/CMSIS/HK32M07x/Source/system_hk32m07x.c</FileName>
              <FileType>1</FileType>
            </File>
          </Files>
        </Group>
        <Group>
          <GroupName>Startup</GroupName>
          <Files>
            <File>
              <FileName>../Mcu/HK32M070/Startup/startup_hk32m07x.s</FileName>
              <FileType>2</FileType>
            </File>
          </Files>
        </Group>
        <Group>
          <GroupName>User</GroupName>
          <Files>
            <File>
              <FileName>../User/main.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../User/conf_general.c</FileName>
              <FileType>1</FileType>
            </File>
          </Files>
        </Group>
        <Group>
          <GroupName>Hardware</GroupName>
          <Files>
            <File>
              <FileName>../hwconf/hw.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../hwconf/hw_conf.c</FileName>
              <FileType>1</FileType>
            </File>
          </Files>
        </Group>
        <Group>
          <GroupName>Motor</GroupName>
          <Files>
            <File>
              <FileName>../motor/foc_hall.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../motor/foc_math.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../motor/mc_interface.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../motor/mcpwm.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../motor/mcpwm_foc.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../motor/virtual_motor.c</FileName>
              <FileType>1</FileType>
            </File>
          </Files>
        </Group>
        <Group>
          <GroupName>Util</GroupName>
          <Files>
            <File>
              <FileName>../util/utils_math.c</FileName>
              <FileType>1</FileType>
            </File>
          </Files>
        </Group>
        <Group>
          <GroupName>StdPeriph</GroupName>
          <Files>
            <File>
              <FileName>../Mcu/HK32M070/Driver/HK32M07x_StdPeriphDriver/src/hk32m07x_adc.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../Mcu/HK32M070/Driver/HK32M07x_StdPeriphDriver/src/hk32m07x_gpio.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../Mcu/HK32M070/Driver/HK32M07x_StdPeriphDriver/src/hk32m07x_rcc.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../Mcu/HK32M070/Driver/HK32M07x_StdPeriphDriver/src/hk32m07x_misc.c</FileName>
              <FileType>1</FileType>
            </File>
            <File>
              <FileName>../Mcu/HK32M070/Driver/HK32M07x_StdPeriphDriver/src/hk32m07x_flash.c</FileName>
              <FileType>1</FileType>
            </File>
          </Files>
        </Group>
      </Groups>
    </Target>
  </Targets>
</Project>